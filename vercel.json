{
  "crons": [
    {
      "path": "/api/cron-publish",
      "schedule": "0 12 * * *"
    }
  ],
  "functions": {
    "api/upload-video.js": {
      "includeFiles": "node_modules/@vercel/blob/**"
    },
    "api/watermark-video.js": {
      "includeFiles": "node_modules/@ffmpeg-installer/**",
      "maxDuration": 60
    },
    "api/document.js": {
      "maxDuration": 30
    }
  }
}
